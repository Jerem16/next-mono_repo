{
    "name": "@repo/services",
    "version": "0.0.0",
    "type": "module",
    "sideEffects": false,
    "exports": {
        ".": {
            "types": "./dist/types/index.d.ts",
            "import": "./src/index.ts"
        },
        "./amplify": {
            "types": "./dist/types/amplify/index.d.ts",
            "import": "./src/amplify/index.ts"
        }
    },
    "types": "./dist/types/index.d.ts",
    "files": [
        "dist",
        "src"
    ],
    "peerDependencies": {
        "@aws-amplify/ui-react": ">=6",
        "react": "^18.3.1",
        "react-dom": "^18.3.1"
    },
    "dependencies": {
        "@repo/amplify": "workspace:*",
        "@repo/domain": "workspace:*",
        "@repo/types": "workspace:*"
    },
    "scripts": {
        "build": "tsc -b",
        "typecheck": "tsc -p tsconfig.json --noEmit",
        "lint": "eslint .",
        "test": "echo \"No tests configured\""
    }
}
