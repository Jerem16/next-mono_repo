{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "composite": true,
    "declaration": true,
    "declarationMap": true,
    "outDir": "dist/types",
    "emitDeclarationOnly": true,
    "baseUrl": ".",
    "paths": {
      "@repo/domain": ["../domain/src/index.ts"],
      "@repo/domain/*": ["../domain/src/*"],
      "@repo/types": ["../types/src/index.ts"],
      "@repo/types/*": ["../types/src/*"],
      "@repo/amplify": ["../../amplify"],
      "@repo/amplify/*": ["../../amplify/*"]
    }
  },
  "include": ["src"],
  "references": [
    { "path": "../domain" },
    { "path": "../types" }
  ]
}
