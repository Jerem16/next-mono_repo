{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "composite": true,
    "declaration": true,
    "declarationMap": true,
    "outDir": "dist/types",
    "emitDeclarationOnly": true,
    "baseUrl": ".",
    "paths": {
      "@repo/services": ["../services/src/index.ts"],
      "@repo/services/*": ["../services/src/*"],
      "@repo/types": ["../types/src/index.ts"],
      "@repo/types/*": ["../types/src/*"]
    }
  },
  "include": ["src"],
  "references": [
    { "path": "../services" },
    { "path": "../types" }
  ]
}
