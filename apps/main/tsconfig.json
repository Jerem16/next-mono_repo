{
    "extends": "../../tsconfig.base.json",
    "compilerOptions": {
        "target": "ES2017",
        "lib": ["dom", "dom.iterable", "esnext"],
        "allowJs": true,
        "skipLibCheck": true,
        "strict": true,
        "noEmit": true,
        "incremental": true,
        "module": "esnext",
        "esModuleInterop": true,
        "moduleResolution": "node",
        "resolveJsonModule": true,
        "isolatedModules": true,
        "jsx": "preserve",
        "baseUrl": "../..",
        "paths": {
            "@/*": ["apps/main/*"],
            "@app/*": ["apps/main/app/*"],
            "@src/*": ["apps/main/src/*"],
            "@public/*": ["apps/main/public/*"]
        },
        "plugins": [
            {
                "name": "next"
            }
        ]
    },
    "include": [
        "next-env.d.ts",
        ".next/types/**/*.ts",
        "**/*.ts",
        "**/*.tsx",
        "middleware.ts"
    ],
    "exclude": ["node_modules"]
}
