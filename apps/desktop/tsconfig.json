{
    "extends": "../../tsconfig.base.json",
    "compilerOptions": {
        "strict": true,
        "noEmit": true,
        "jsx": "preserve",
        "incremental": true,
        "allowJs": true,
        "skipLibCheck": true,
        "esModuleInterop": true,
        "resolveJsonModule": true,
        "isolatedModules": true,
        "lib": ["dom", "dom.iterable", "esnext"],
        "baseUrl": "../..",
        "paths": {
            "@/*": ["apps/desktop/*"],
            "@app/*": ["apps/desktop/app/*"],
            "@src/*": ["apps/desktop/src/*"],
            "@public/*": ["apps/desktop/public/*"],
            "@assets/*": ["apps/desktop/src/assets/*"],
            "@components/*": ["apps/desktop/src/components/*"],
            "@features/*": ["apps/desktop/src/features/*"],
            "@hooks/*": ["apps/desktop/src/hooks/*"],
            "@context/*": ["apps/desktop/src/utils/context/*"],
            "@utils/*": ["apps/desktop/src/utils/*"],
            "@nav/*": ["apps/desktop/src/features/navigation/*"],
            "@nav-components/*": ["apps/desktop/src/features/navigation/components/*"],
            "@nav-data/*": ["apps/desktop/src/features/navigation/data/*"],
            "@nav-icons/*": ["apps/desktop/src/features/navigation/icons/*"],
            "@nav-types/*": ["apps/desktop/src/features/navigation/types/*"],
            "@nav-utils/*": ["apps/desktop/src/features/navigation/utils/*"]
        },
        "plugins": [{ "name": "next" }]
    },
    "include": [
        "next-env.d.ts",
        "global.d.ts",
        "app/**/*.ts",
        "app/**/*.tsx",
        "app/**/*.js",
        "app/**/*.jsx",
        "src/**/*.ts",
        "src/**/*.tsx",
        "src/**/*.js",
        "src/**/*.jsx",
        "public/**/*.json",
        ".next/types/**/*.ts"
    ],
    "exclude": ["node_modules"],
    "references": [
        { "path": "../../packages/types" },
        { "path": "../../packages/domain" },
        { "path": "../../packages/services" },
        { "path": "../../packages/ui" }
    ]
}
