{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "incremental": true,
    "noEmit": true,
    "types": [
      "node"
    ],
    "allowJs": true,
    "jsx": "preserve",
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "./*"
      ],
      "@amplify": [
        "amplify"
      ],
      "@amplify/*": [
        "amplify/*"
      ],
      "@src/*": [
        "src/*"
      ],
      "@app/*": [
        "app/*"
      ],
      "@assets/*": [
        "src/assets/*"
      ],
      "@components/*": [
        "src/components/*"
      ],
      "@hooks/*": [
        "src/hooks/*"
      ],
      "@context/*": [
        "src/utils/context/*"
      ],
      "@utils/*": [
        "src/utils/*"
      ],
      "@public/*": [
        "public/*"
      ],
      "@ui/*": [
        "../../packages/ui/src/*"
      ],
      "@domain/*": [
        "../../packages/domain/src/*"
      ],
      "@services/*": [
        "../../packages/services/src/*"
      ],
      "@types/*": [
        "../../packages/types/src/*"
      ]
    },
    "plugins": [
      {
        "name": "next"
      }
    ],
    "esModuleInterop": true
  },
  "include": [
    "next-env.d.ts",
    "app/**/*.ts",
    "app/**/*.tsx",
    "app/**/*.js",
    "app/**/*.jsx",
    "src/**/*.ts",
    "src/**/*.tsx",
    "src/**/*.js",
    "src/**/*.jsx",
    "public/**/*.json",
    ".next/types/**/*.ts"
  ],
  "exclude": [
    "node_modules"
  ],
  "references": [
    {
      "path": "../../packages/types"
    },
    {
      "path": "../../packages/domain"
    },
    {
      "path": "../../packages/services"
    },
    {
      "path": "../../packages/ui"
    }
  ]
}
