{
    "$schema": "https://turbo.build/schema.json",
    "tasks": {
        "build": {
            "dependsOn": ["^build"],
            "outputs": ["dist/**", "build/**", ".next/**"]
        },
        "dev": {
            "cache": false
        },
        "lint": {
            "dependsOn": ["^lint"]
        },
        "start": {
            "dependsOn": ["^start"],
            "cache": false
        },
        "test": {
            "dependsOn": ["^test"],
            "outputs": ["coverage/**"]
        },
        "tsc": {
            "dependsOn": ["^tsc"]
        }
    }
}
