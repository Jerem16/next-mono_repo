{
  "name": "root",
  "private": true,
  "packageManager": "yarn@4.0.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev --parallel",
    "dev:mobile": "yarn --cwd apps/mobile dev",
    "dev:desktop": "yarn --cwd apps/desktop dev",
    "dev:main": "yarn --cwd apps/main dev",
    "build": "turbo run build",
    "build:mobile": "yarn --cwd apps/mobile build",
    "build:desktop": "yarn --cwd apps/desktop build",
    "build:main": "yarn --cwd apps/main build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "analyze": "cross-env ANALYZE=1 turbo run build"
  },
  "devDependencies": {
    "@next/eslint-plugin-next": "^15.5.3",
    "@types/node": "^20.14.10",
    "cross-env": "^7.0.3",
    "eslint": "^9.11.0",
    "turbo": "^2.1.3",
    "typescript": "^5.6.2",
    "typescript-eslint": "^8.44.0",
    "webpack-bundle-analyzer": "^4.10.2"
  },
  "engines": {
    "node": ">=20.11.0"
  },
  "resolutions": {
    "react-hook-form": "7.51.5"
  }
}
